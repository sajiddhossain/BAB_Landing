# --- Supabase: cattura lead (waitlist B2C + form Società B2B) ---
# La chiave anon/publishable è sicura lato client SOLO se la tabella ha RLS con
# la sola policy INSERT per il ruolo `anon`. Vedi docs/supabase_setup.sql
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_LEADS_TABLE=leads

# --- Analytics: lasciare VUOTO per disattivare. Si attivano solo con ID reali. ---
# GA4 nel formato G-XXXXXXXX, Meta Pixel solo cifre.
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=

# --- Backend legacy opzionale (non usato dalla cattura lead Supabase) ---
VITE_API_URL=https://api.bab-sports.com/v1
