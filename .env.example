# --- Supabase: cattura lead (waitlist B2C + form Società B2B) ---
# La chiave anon/publishable è sicura lato client SOLO se la tabella ha RLS con
# la sola policy INSERT per il ruolo `anon`. Vedi docs/supabase_setup.sql
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_LEADS_TABLE=leads

# --- Analytics: lasciare VUOTO per disattivare. Si attivano solo con ID reali. ---
# GA4 nel formato G-XXXXXXXX, Meta Pixel solo cifre (richiedono consenso cookie).
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
# Cloudflare Web Analytics: token esadecimale dal pannello CF. Cookieless →
# si attiva senza banner consenso. Lasciare vuoto per disattivare.
VITE_CLOUDFLARE_ANALYTICS_TOKEN=

# --- Email bridge: notifica lead al team (funzione Vercel /api/notify-lead) ---
# Variabili SERVER (niente prefisso VITE_ → non finiscono nel bundle client).
# Da impostare nel pannello Vercel (Project → Settings → Environment Variables).
# Vedi docs/email-bridge.md per il setup completo (Resend + verifica dominio).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Destinatario delle notifiche (default nel codice: info@babsport.com)
LEAD_NOTIFY_TO=info@babsport.com
# Mittente: deve essere su un dominio verificato in Resend. Prima della verifica
# del dominio babsport.com si può usare il dominio condiviso onboarding@resend.dev.
LEAD_NOTIFY_FROM=BAB · Waitlist <waitlist@babsport.com>
# Origin ammessi per POST all'endpoint (anti-abuso), separati da virgola.
LEAD_NOTIFY_ALLOWED_ORIGINS=https://www.babsport.com,https://babsport.com

# Flag CLIENT opzionale: impostare a "off" per NON chiamare l'endpoint di notifica
# (utile in dev locale senza `vercel dev`). Vuoto/assente = attivo.
VITE_LEAD_NOTIFY=

# --- Backend legacy opzionale (non usato dalla cattura lead Supabase) ---
VITE_API_URL=https://api.bab-sports.com/v1
